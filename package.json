{
  "name": "@jaringan-dagang/protocol-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the Jaringan Dagang protocol packages + reference apps. Not published.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetatechID/jaringan-dagang-protocol.git"
  },
  "scripts": {
    "build": "turbo run build --no-daemon",
    "test": "vitest run --config vitest.config.ts && turbo run test --no-daemon",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:browser": "playwright test",
    "test:llm": "vitest run --config vitest.llm.config.ts",
    "lint": "turbo run lint --no-daemon",
    "typecheck": "turbo run typecheck --no-daemon",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --no-daemon --filter='./packages/*' && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@playwright/test": "^1.48.0",
    "turbo": "^2.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0"
}