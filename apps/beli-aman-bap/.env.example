# Beli Aman BAP — local-dev environment template.
# Copy to .env and fill in. NEVER commit a populated .env.

# --- Database ---
# In dev, points at the postgres in jaringan-dagang-network/docker-compose.yml
# (port 5433) with a separate database `beli_aman` (created by the override compose
# in infra/beli-aman/).
DATABASE_URL=postgresql+asyncpg://jaringan:jaringan_dev@localhost:5433/beli_aman

# --- Firebase Admin ---
# Paste the entire service-account JSON file contents on a single line.
# Get this from Firebase console -> Project settings -> Service accounts ->
# Generate new private key. NEVER commit.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Demo / admin ---
# Random shared secret. MUST match NEXT_PUBLIC_ADMIN_DEMO_TOKEN on the storefront.
ADMIN_TOKEN=dev-admin-token

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# --- Seller bridge ---
# When an order moves to ESCROW_HELD we best-effort POST it to this URL so it
# shows up in the seller dashboard.
SELLER_BRIDGE_URL=http://localhost:8001
SELLER_BRIDGE_TOKEN=dev-seller-bridge-token
SELLER_BRIDGE_ENABLED=true

# --- Beckn (parity with JD BAP; unused in v1) ---
# Canonical subscriber_id (Task A3): the network-wide identity is
# *.jaringan-dagang.id regardless of the DNS host the BAP is deployed at.
SUBSCRIBER_ID=beli-aman.bap.jaringan-dagang.id
SUBSCRIBER_URL=http://localhost:8003/api/v1/beckn
REGISTRY_URL=http://localhost:3030
GATEWAY_URL=http://localhost:4030

# --- Payment gateways ---
# Master Xendit secret (Basic auth username). For real invoices, set
# XENDIT_WEBHOOK_TOKEN too and register XENDIT_CALLBACK_BASE_URL in the
# Xendit dashboard.
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_CALLBACK_BASE_URL=http://127.0.0.1:8003
XENDIT_INVOICE_DURATION_SECONDS=86400
# Master OY API key (per-Brand override in Brand.oy_api_key). Leave empty
# to run OY in mock-checkout fallback mode (returns /api/mock-checkout/...
# URLs) — useful for local dev without an OY sandbox account.
OY_API_KEY=
OY_DEFAULT_USERNAME=
OY_CALLBACK_BASE_URL=http://127.0.0.1:8003

# --- Sento Payment Link (sandbox by default; override for prod) ---
# Default points at the staging host so dev / e2e tests don't hit prod.
# Flip SENTO_BASE_URL=https://partner.sento.id for production.
# Per-Brand override via Brand.sento_api_key / Brand.sento_username. Register
# SENTO_CALLBACK_BASE_URL + the VM's outbound IP in the Sento dashboard
# before flipping any Brand.payment_provider='sento'.
# QRIS-only scope for now — see services/sento_client.py for the
# list_enabled_banks default.
SENTO_BASE_URL=https://api-demo.sento.id
SENTO_API_KEY=
SENTO_DEFAULT_USERNAME=
SENTO_CALLBACK_BASE_URL=http://127.0.0.1:8003
SENTO_INVOICE_DURATION_SECONDS=86400
